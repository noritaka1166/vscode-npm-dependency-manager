{
  "name": "npm-dependency-manager",
  "displayName": "npm-dependency-manager",
  "description": "Inspect workspace npm dependencies, updates, package-lock data, README content, and vulnerability signals from the VS Code sidebar.",
  "version": "0.0.4",
  "publisher": "noritaka1166",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#102333",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noritaka1166/vscode-npm-dependency-manager.git"
  },
  "bugs": {
    "url": "https://github.com/noritaka1166/vscode-npm-dependency-manager/issues"
  },
  "homepage": "https://github.com/noritaka1166/vscode-npm-dependency-manager#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Visualization"
  ],
  "keywords": [
    "npm",
    "dependencies",
    "dependency manager",
    "package.json",
    "package-lock",
    "npm audit",
    "vulnerability",
    "security",
    "audit",
    "outdated",
    "license",
    "node",
    "nodejs",
    "javascript",
    "typescript",
    "updates"
  ],
  "qna": false,
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js && node --check lib/security.js && node --check media/main.js",
    "vscode:prepublish": "npm run check",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workspaceNpmSidebar",
          "title": "npm Packages",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "workspaceNpmSidebar": [
        {
          "id": "workspaceNpmSidebar.dependenciesView",
          "name": "Dependencies"
        }
      ]
    },
    "commands": [
      {
        "command": "workspaceNpmSidebar.show",
        "title": "npm Packages: Show Dashboard"
      },
      {
        "command": "workspaceNpmSidebar.refresh",
        "title": "npm Packages: Refresh"
      },
      {
        "command": "workspaceNpmSidebar.openPackage",
        "title": "npm Packages: Open Package"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0"
  },
  "dependencies": {
    "markdown-it": "^14.2.0"
  }
}
